{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/data/besigner/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/core/data/besigner",
        "main": "libs/core/data/besigner/src/index.ts",
        "tsConfig": "libs/core/data/besigner/tsconfig.lib.json",
        "assets": ["libs/core/data/besigner/*.md"]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/core/data/besigner/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/libs/core/data/besigner"],
      "options": {
        "jestConfig": "libs/core/data/besigner/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["scope:lib", "scope:aglyn", "scope:data", "aglyn:besigner"]
}
