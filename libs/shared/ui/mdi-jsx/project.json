{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/ui/mdi-jsx/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/web:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/ui/mdi-jsx",
        "tsConfig": "libs/shared/ui/mdi-jsx/tsconfig.lib.json",
        "project": "libs/shared/ui/mdi-jsx/package.json",
        "entryFile": "libs/shared/ui/mdi-jsx/src/index.ts",
        "external": ["react/jsx-runtime"],
        "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
        "compiler": "swc",
        "assets": [
          {
            "glob": "libs/shared/ui/mdi-jsx/README.md",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/shared/ui/mdi-jsx/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/libs/shared/ui/mdi-jsx"],
      "options": {
        "jestConfig": "libs/shared/ui/mdi-jsx/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["scope:lib", "scope:shared", "scope:ui"]
}
