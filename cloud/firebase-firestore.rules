rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    // Staff access is a Firebase custom claim set via
    // tools/scripts/set-staff-claim.mjs (Aglyn Admin Console, AGL-42).
    function isStaff() { return isSignedIn() && request.auth.token.staff == true; }

    // Hosts and everything under them are scoped to the host's admins map
    // (content-hardening review, 2026-07-07): the previous any-authed access
    // let any signed-up account write other tenants' screens — a stored-XSS
    // and defacement vector once rich text landed. Tenant sites read through
    // the Admin SDK (bypasses rules), so no public read is needed here.
    function isHostAdmin(hostId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/hosts/$(hostId))
          .data.admins[request.auth.uid] == true;
    }
    match /hosts/{hostId} {
      // Queries must be admin-constrained (the console filters on
      // admins.{uid} == true), which this rule admits.
      allow read: if isStaff() || (isSignedIn() &&
        resource.data.admins[request.auth.uid] == true);
      allow create: if isSignedIn() &&
        request.resource.data.admins[request.auth.uid] == true;
      allow update, delete: if isStaff() ||
        (isSignedIn() && resource.data.admins[request.auth.uid] == true);
      match /{document=**} {
        allow read, write: if isStaff() || isHostAdmin(hostId);
      }
    }

    // Tenant docs (billing v1: keyed by the owner's uid). Owners read their
    // own doc; clients never write plan/subscription — the Stripe webhook
    // and admin tooling write via the Admin SDK (which bypasses rules), and
    // staff may write from the admin console.
    match /tenants/{tenantId} {
      allow read: if isStaff() || (isSignedIn() && request.auth.uid == tenantId);
      allow write: if isStaff();
    }

    // Staff-only, append-only audit log of admin actions
    // ({ actorUid, action, target, before, after, at }).
    match /adminAudit/{entryId} {
      allow read, create: if isStaff();
      allow update, delete: if false;
    }
  }
}
